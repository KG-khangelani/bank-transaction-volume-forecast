Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Run", " ", "file", " ", "verification", " ", "to", " ", "ensure", " ", 
    "all", " ", "necessary", " ", "files", " ", "are", " ", "present"}], " ", 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"VerifyBankForecastFiles", "[", "]"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Import", " ", "the", " ", "datasets", " ", "using", " ", "the", " ", 
     "specified", " ", "helper", " ", "functions"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"trainLabels", "=", 
    RowBox[{"ImportBankForecastFile", "[", "\"\<TrainLabels\>\"", "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"testCustomers", "=", 
    RowBox[{"ImportBankForecastFile", "[", "\"\<TestCustomers\>\"", "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"variableDefinitions", "=", 
    RowBox[{
    "ImportBankForecastFile", "[", "\"\<VariableDefinitions\>\"", "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"demographics", "=", 
    RowBox[{"ImportBankForecastFile", "[", "\"\<Demographics\>\"", "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"financials", "=", 
    RowBox[{"ImportBankForecastFile", "[", "\"\<Financials\>\"", "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "If", " ", "loading", " ", "the", " ", "full", " ", "Transactions", " ", 
      "table", " ", "is", " ", "slow"}], ",", " ", 
     RowBox[{"create", " ", "a", " ", "sample"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"transactions", "=", 
    RowBox[{"ImportBankForecastFile", "[", "\"\<Transactions\>\"", "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"transactionSample", "=", 
    RowBox[{"RandomSample", "[", 
     RowBox[{"transactions", ",", 
      RowBox[{"Min", "[", 
       RowBox[{"1000", ",", 
        RowBox[{"Length", "[", "transactions", "]"}]}], "]"}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Function", " ", "to", " ", "print", " ", "row", " ", "counts"}],
      ",", " ", 
     RowBox[{"column", " ", "names"}], ",", " ", "types", ",", " ", 
     RowBox[{"and", " ", "sample", " ", "rows"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"printTableInfo", "[", 
     RowBox[{"data_", ",", "name_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"cols", ",", "types", ",", "sample"}], "}"}], ",", 
      "\[IndentingNewLine]", "  ", 
      RowBox[{
       RowBox[{"cols", "=", 
        RowBox[{"Keys", "[", 
         RowBox[{"First", "[", "data", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", "  ", 
       RowBox[{"types", "=", 
        RowBox[{"Head", " ", "/@", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"data", "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", "#"}], "]"}], "]"}], " ", "&"}], ")"}], " ",
           "/@", " ", "cols"}]}]}], ";", "\[IndentingNewLine]", "  ", 
       RowBox[{"sample", "=", 
        RowBox[{"Take", "[", 
         RowBox[{"data", ",", "5"}], "]"}]}], ";", "\[IndentingNewLine]", 
       "  ", 
       RowBox[{"Print", "[", 
        RowBox[{"name", ",", "\"\<: \>\"", ",", 
         RowBox[{"Length", "[", "data", "]"}], ",", "\"\< rows\>\""}], "]"}], 
       ";", "\[IndentingNewLine]", "  ", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Columns: \>\"", ",", "cols"}], "]"}], ";", 
       "\[IndentingNewLine]", "  ", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Types: \>\"", ",", "types"}], "]"}], ";", 
       "\[IndentingNewLine]", "  ", 
       RowBox[{"Print", "[", "\"\<Sample Rows:\>\"", "]"}], ";", 
       "\[IndentingNewLine]", "  ", 
       RowBox[{"Print", "[", 
        RowBox[{"Grid", "[", 
         RowBox[{"sample", ",", 
          RowBox[{"Frame", "->", "All"}]}], "]"}], "]"}]}]}], 
     "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
